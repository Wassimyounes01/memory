# Memory — copy to `.env` and fill in. Never commit your real `.env`.
# Every value below is a placeholder; nothing here ties to any account.

MEMORY_RERANKER=   # optional path to an LLM reranker module (see examples/reranker-echo.cjs); blank = keyword/recency recall
MEMORY_DATA_DIR=   # optional override for the ./data directory; blank = <repo>/data
